<Page x:Class="Invetario.Views.NuevoProductoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Nuevo Producto">
    <Grid Margin="20">
        <StackPanel Width="400" VerticalAlignment="Top">
            <TextBlock Text="➕ Ingresar Producto" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Código de Barras:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtCodigo" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

            <TextBlock Text="Nombre:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtNombre" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

            <TextBlock Text="Precio:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtPrecio" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

            <TextBlock Text="Stock:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtStock" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

            <Button Content="GUARDAR" Height="40" Margin="0,25,0,0"
                    Background="#27AE60" Foreground="White" FontWeight="Bold"
                    Click="btnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Page>
