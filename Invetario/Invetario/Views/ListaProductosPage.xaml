<Page x:Class="Invetario.Views.ListaProductosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Lista de Productos">
    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top" Text="📦 Lista de Productos" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🔍 Buscar Producto:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBox x:Name="txtFiltro" Width="300" Height="30" FontSize="16" 
         VerticalContentAlignment="Center" TextChanged="txtFiltro_TextChanged"/>
            <Label Content="Categoría:"/>
            <ComboBox x:Name="cmbCategorias" DisplayMemberPath="Nombre" SelectedValuePath="Id"
                     SelectionChanged="cmbCategorias_SelectionChanged"/>
            <Button Content="🔄 Actualizar" Click="btnActualizarLista_Click" 
                    Width="120" Height="30" Margin="10,0,0,0"
                    Background="#2980B9" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="⬅ Anterior" Click="btnPaginaAnterior_Click" Width="100" Margin="5"/>
            <TextBlock x:Name="txtPagina" Text="Página 1" VerticalAlignment="Center" FontWeight="Bold" Margin="10,0"/>
            <Button Content="Siguiente ➡" Click="btnPaginaSiguiente_Click" Width="100" Margin="5"/>
        </StackPanel>

        <DataGrid x:Name="dgProductos" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Acción">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🛒 Vender" Click="btnVenderDesdeLista_Click" 
                Background="#27ae60" Foreground="White" Padding="10,2" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarras}" Width="150"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Categoría" Binding="{Binding CategoriaNombre}" Width="120"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="150"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
