<Window x:Class="Invetario.Views.TicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket de Venta" Width="340" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F9F9F9">
    <DockPanel Margin="0">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="🖨 Imprimir" Click="btnImprimir_Click"
                    Width="130" Height="35" FontSize="14" FontWeight="Bold"
                    Background="#27AE60" Foreground="White" Cursor="Hand"/>
            <Button Content="Cerrar" Click="btnCerrar_Click"
                    Width="100" Height="35" FontSize="14" FontWeight="Bold"
                    Background="#95A5A6" Foreground="White" Cursor="Hand" Margin="10,0,0,0"/>
        </StackPanel>

        <Border x:Name="ContenedorTicket" Width="300" Margin="0" Padding="0" Background="White"
                HorizontalAlignment="Center" BorderBrush="#BDC3C7" BorderThickness="1">
            <FlowDocumentScrollViewer x:Name="viewerTicket" VerticalScrollBarVisibility="Auto"
                                       HorizontalScrollBarVisibility="Disabled" IsToolBarVisible="False"
                                       Margin="0" Padding="0" FontFamily="Consolas" FontSize="11"/>
        </Border>
    </DockPanel>
</Window>
