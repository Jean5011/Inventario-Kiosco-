-- ============================================================
-- Script para generar TODOS los INSERT de KioscoDB
-- Ejecutar en SSMS con Ctrl+T (Results to Text)
-- Copiar el resultado y ejecutarlo en la BD destino
-- ============================================================

-- Construir resultado final con IDENTITY_INSERT por tabla
DECLARE @categorias NVARCHAR(MAX) = '';
DECLARE @usuarios NVARCHAR(MAX) = '';
DECLARE @productos NVARCHAR(MAX) = '';
DECLARE @ventas NVARCHAR(MAX) = '';
DECLARE @detalles NVARCHAR(MAX) = '';

-- CATEGORIAS
SELECT @categorias = @categorias + 
	'INSERT INTO Categorias (Id, Nombre, EsPesable) VALUES ('
	+ CAST(Id AS NVARCHAR) + ', '
	+ '''' + REPLACE(Nombre, '''', '''''') + ''', '
	+ CAST(EsPesable AS NVARCHAR) + ');' + CHAR(13)
FROM Categorias ORDER BY Id;

-- USUARIOS
SELECT @usuarios = @usuarios + 
	'INSERT INTO Usuarios (Id, Username, Password, Rol, sexo, Ruta_foto, NombreReal) VALUES ('
	+ CAST(Id AS NVARCHAR) + ', '
	+ '''' + REPLACE(Username, '''', '''''') + ''', '
	+ '''' + REPLACE(Password, '''', '''''') + ''', '
	+ '''' + REPLACE(Rol, '''', '''''') + ''', '
	+ '''' + REPLACE(ISNULL(sexo, ''), '''', '''''') + ''', '
	+ '''' + REPLACE(ISNULL(Ruta_foto, ''), '''', '''''') + ''', '
	+ '''' + REPLACE(ISNULL(NombreReal, ''), '''', '''''') + ''');' + CHAR(13)
FROM Usuarios ORDER BY Id;

-- PRODUCTOS
SELECT @productos = @productos + 
	'INSERT INTO Productos (Id, CodigoBarras, Nombre, Descripcion, PrecioCosto, PrecioVenta, CategoriaId, Stock) VALUES ('
	+ CAST(Id AS NVARCHAR) + ', '
	+ '''' + REPLACE(CodigoBarras, '''', '''''') + ''', '
	+ '''' + REPLACE(Nombre, '''', '''''') + ''', '
	+ '''' + REPLACE(ISNULL(Descripcion, ''), '''', '''''') + ''', '
	+ CAST(PrecioCosto AS NVARCHAR) + ', '
	+ CAST(PrecioVenta AS NVARCHAR) + ', '
	+ CAST(CategoriaId AS NVARCHAR) + ', '
	+ CAST(Stock AS NVARCHAR) + ');' + CHAR(13)
FROM Productos ORDER BY Id;

-- VENTAS
SELECT @ventas = @ventas + 
	'INSERT INTO Ventas (Id, FechaVenta, TotalVenta, MetodoPago) VALUES ('
	+ CAST(Id AS NVARCHAR) + ', '
	+ '''' + CONVERT(NVARCHAR, FechaVenta, 121) + ''', '
	+ CAST(TotalVenta AS NVARCHAR) + ', '
	+ '''' + REPLACE(ISNULL(MetodoPago, 'Efectivo'), '''', '''''') + ''');' + CHAR(13)
FROM Ventas ORDER BY Id;

-- DETALLE DE VENTAS
SELECT @detalles = @detalles + 
	'INSERT INTO DetalleVentas (Id, IdVenta, IdProducto, Cantidad, PrecioUnitario, Preciototal) VALUES ('
	+ CAST(Id AS NVARCHAR) + ', '
	+ CAST(IdVenta AS NVARCHAR) + ', '
	+ CAST(IdProducto AS NVARCHAR) + ', '
	+ CAST(Cantidad AS NVARCHAR) + ', '
	+ CAST(PrecioUnitario AS NVARCHAR) + ', '
	+ CAST(Preciototal AS NVARCHAR) + ');' + CHAR(13)
FROM DetalleVentas ORDER BY Id;

-- Imprimir todo junto con IDENTITY_INSERT
PRINT '-- CATEGORIAS';
PRINT 'SET IDENTITY_INSERT Categorias ON;';
PRINT @categorias;
PRINT 'SET IDENTITY_INSERT Categorias OFF;';
PRINT '';
PRINT '-- USUARIOS';
PRINT 'SET IDENTITY_INSERT Usuarios ON;';
PRINT @usuarios;
PRINT 'SET IDENTITY_INSERT Usuarios OFF;';
PRINT '';
PRINT '-- PRODUCTOS';
PRINT 'SET IDENTITY_INSERT Productos ON;';
PRINT @productos;
PRINT 'SET IDENTITY_INSERT Productos OFF;';
PRINT '';
PRINT '-- VENTAS';
PRINT 'SET IDENTITY_INSERT Ventas ON;';
PRINT @ventas;
PRINT 'SET IDENTITY_INSERT Ventas OFF;';
PRINT '';
PRINT '-- DETALLE DE VENTAS';
PRINT 'SET IDENTITY_INSERT DetalleVentas ON;';
PRINT @detalles;
PRINT 'SET IDENTITY_INSERT DetalleVentas OFF;';
