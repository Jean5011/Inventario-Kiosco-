-- ============================================
-- Script para respaldar e insertar datos
-- Base de datos: KioscoDB
-- Fecha: Generado desde la aplicación Inventario
-- ============================================

-- =====================
-- 1. CATEGORIAS
-- =====================
-- Habilitar IDENTITY_INSERT para insertar con Id
SET IDENTITY_INSERT Categorias ON;

INSERT INTO Categorias (Id, Nombre, EsPesable)
SELECT Id, Nombre, EsPesable
FROM Categorias;
-- NOTA: Esta consulta es una plantilla. Reemplaza con los valores reales.
-- Ejemplo:
-- INSERT INTO Categorias (Id, Nombre, EsPesable) VALUES (1, 'Bebidas', 0);
-- INSERT INTO Categorias (Id, Nombre, EsPesable) VALUES (2, 'Frutas', 1);

SET IDENTITY_INSERT Categorias OFF;
GO

