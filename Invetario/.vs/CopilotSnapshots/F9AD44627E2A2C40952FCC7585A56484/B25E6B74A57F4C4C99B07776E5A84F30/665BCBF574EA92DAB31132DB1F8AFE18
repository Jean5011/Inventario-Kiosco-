<Page x:Class="Invetario.Views.VentasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ventas"
      Loaded="VentasPage_Loaded">
    <DockPanel Margin="20">
        <!-- Scanner oculto: captura el flujo de manos libres del escáner HID -->
        <TextBox x:Name="txtScanner" Width="0" Height="0" Opacity="0"
                 KeyDown="txtScanner_KeyDown" LostFocus="txtScanner_LostFocus"/>
        <TextBlock DockPanel.Dock="Top" Text="🛒 Nueva Venta" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Código de barras:" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                <TextBox x:Name="txtCodigo" Width="350" Height="40" FontSize="18"
                         VerticalContentAlignment="Center"
                         Tag="Escanear código de barras..." KeyDown="txtCodigo_KeyDown"/>
                <TextBlock x:Name="lblProductoPesable" Text="" FontSize="14" FontWeight="Bold"
                           Foreground="#E67E22" VerticalAlignment="Center" Margin="15,0,10,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Buscar por nombre:" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                <TextBox x:Name="txtNombre" Width="300" Height="40" FontSize="18"
                         VerticalContentAlignment="Center" KeyDown="txtNombre_KeyDown"/>
                <Button Content="🔍 Buscar" Width="100" Height="40" FontSize="14"
                        Background="#2980B9" Foreground="White" FontWeight="Bold"
                        Cursor="Hand" Margin="8,0,0,0" Click="btnBuscarNombre_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,15,0,0">
            <Button Content="🗑 Limpiar Carrito" Click="btnLimpiarCarrito_Click"
                    Width="150" Height="35" FontSize="14" FontWeight="Bold"
                    Background="#E74C3C" Foreground="White" Cursor="Hand"/>
            <Button Content="💰 Cerrar Venta" Click="btnCerrarVenta_Click"
                    Width="160" Height="35" FontSize="14" FontWeight="Bold"
                    Background="#27AE60" Foreground="White" Cursor="Hand" Margin="10,0,0,0"/>
            <TextBlock x:Name="lblTotal" Text="Total: $0.00" FontSize="20" 
                       FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <DataGrid x:Name="dgCarrito" AutoGenerateColumns="False" Margin="0,10,0,0"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="❌" Click="btnEliminarFila_Click"
                                    Background="#E74C3C" Foreground="White" FontWeight="Bold"
                                    Padding="6,2" Cursor="Hand" ToolTip="Eliminar fila"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarras}" Width="150"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C2}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
