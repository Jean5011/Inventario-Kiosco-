<Page x:Class="Invetario.Views.ReportesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reportes de Ventas" Background="White">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Periodo rápido:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <ComboBox x:Name="cmbPeriodo" Width="150" SelectionChanged="cmbPeriodo_SelectionChanged">
                    <ComboBoxItem Content="Hoy" IsSelected="True"/>
                    <ComboBoxItem Content="Esta Semana"/>
                    <ComboBoxItem Content="Este Mes"/>
                    <ComboBoxItem Content="Este Año"/>
                </ComboBox>

                <TextBlock x:Name="lblTotalPeriodo" Text="Total: $0.00" FontSize="20" 
                           Foreground="#28a745" FontWeight="Bold" Margin="50,0,0,0"/>
            </StackPanel>

            <Border BorderBrush="#BDC3C7" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,5,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filtro específico:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>

                    <TextBlock Text="Día:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbDia" Width="60">
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                    </ComboBox>

                    <TextBlock Text="Mes:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <ComboBox x:Name="cmbMes" Width="120">
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                        <ComboBoxItem Content="Enero"/>
                        <ComboBoxItem Content="Febrero"/>
                        <ComboBoxItem Content="Marzo"/>
                        <ComboBoxItem Content="Abril"/>
                        <ComboBoxItem Content="Mayo"/>
                        <ComboBoxItem Content="Junio"/>
                        <ComboBoxItem Content="Julio"/>
                        <ComboBoxItem Content="Agosto"/>
                        <ComboBoxItem Content="Septiembre"/>
                        <ComboBoxItem Content="Octubre"/>
                        <ComboBoxItem Content="Noviembre"/>
                        <ComboBoxItem Content="Diciembre"/>
                    </ComboBox>

                    <TextBlock Text="Año:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <ComboBox x:Name="cmbAnio" Width="80">
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                    </ComboBox>

                    <Button Content="🔍 Filtrar" Click="btnFiltroEspecifico_Click"
                            Width="100" Height="30" Margin="15,0,0,0"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                    <Button Content="🔄 Limpiar" Click="btnLimpiarFiltro_Click"
                            Width="90" Height="30" Margin="10,0,0,0"
                            Background="#95A5A6" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <DataGrid x:Name="dgVentas" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Venta" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="*"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="*"/>
                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="120"/>

                <DataGridTemplateColumn Header="Acciones" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="👁 Ver Ticket" Click="btnVerTicket_Click" 
                                    Background="#17a2b8" Foreground="White" Padding="5,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>