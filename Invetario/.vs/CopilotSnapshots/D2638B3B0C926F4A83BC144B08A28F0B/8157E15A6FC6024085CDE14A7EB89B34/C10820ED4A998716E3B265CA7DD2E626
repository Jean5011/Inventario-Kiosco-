<Window x:Class="Invetario.Views.SeleccionProductoWindow" Icon="/icono.png"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Producto" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Se encontraron varios productos. Seleccione uno:" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgResultados" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" MouseDoubleClick="dgResultados_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarras}" Width="120"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding PrecioVenta, StringFormat=C2}" Width="80"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Seleccionar" Width="100" Height="35" Background="#28a745" Foreground="White" 
                    FontWeight="Bold" Click="btnSeleccionar_Click" Margin="0,0,10,0"/>
            <Button Content="Cancelar" Width="100" Height="35" Background="#dc3545" Foreground="White" 
                    FontWeight="Bold" Click="btnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
