<Window x:Class="Invetario.Views.PesableDialog" Icon="/icono.png"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚖ Producto Pesable" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height" Width="420"
        Background="#2C3E50">
    <Border Margin="20" CornerRadius="10" Background="White" Padding="25">
        <StackPanel>
            <!-- Icono y título -->
            <TextBlock Text="⚖" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock x:Name="txtTitulo" Text="Producto Pesable" 
                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" 
                       Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBlock x:Name="txtNombreProducto" Text="" 
                       FontSize="14" HorizontalAlignment="Center" 
                       Foreground="#7F8C8D" Margin="0,0,0,5"/>
            <TextBlock x:Name="txtPrecioKg" Text="" 
                       FontSize="13" HorizontalAlignment="Center" 
                       Foreground="#27AE60" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <Separator Margin="0,0,0,15"/>

            <!-- Entrada de Kilogramos -->
            <TextBlock Text="Kilogramos (kg):" FontWeight="SemiBold" FontSize="14" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBox x:Name="txtKg" FontSize="20" Height="40" 
                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                     BorderBrush="#3498DB" BorderThickness="2"
                     Text="0" GotFocus="txt_GotFocus" TextChanged="txtPeso_TextChanged"/>

            <!-- Entrada de Gramos -->
            <TextBlock Text="Gramos (gr):" FontWeight="SemiBold" FontSize="14" Foreground="#2C3E50" Margin="0,10,0,5"/>
            <TextBox x:Name="txtGr" FontSize="20" Height="40" 
                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                     BorderBrush="#3498DB" BorderThickness="2"
                     Text="0" GotFocus="txt_GotFocus" TextChanged="txtPeso_TextChanged"/>

            <!-- Resumen -->
            <Border Background="#ECF0F1" CornerRadius="8" Padding="12" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock x:Name="txtPesoTotal" Text="Peso total: 0.000 kg" 
                               FontSize="14" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtMontoCalculado" Text="Monto: $0.00" 
                               FontSize="18" FontWeight="Bold" Foreground="#27AE60" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Botones -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="✅ Agregar" x:Name="btnAceptar" Click="btnAceptar_Click"
                        Width="130" Height="38" FontSize="15" FontWeight="Bold"
                        Background="#27AE60" Foreground="White" Margin="0,0,10,0"
                        Cursor="Hand"/>
                <Button Content="❌ Cancelar" Click="btnCancelar_Click"
                        Width="130" Height="38" FontSize="15" FontWeight="Bold"
                        Background="#E74C3C" Foreground="White"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
