<Page x:Class="Invetario.Views.NuevaCategoriaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Nueva Categoria" Height="450" Width="800" Background="White">

    <Grid Margin="20">
        <StackPanel Width="300" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Agregar Nueva Categoría" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <Label Content="Nombre de la Categoría:"/>
            <TextBox x:Name="txtNombre" Margin="0,0,0,15" Padding="5"/>

            <CheckBox x:Name="chkEsPesable" Content="¿Es un producto pesable? (Fiambre/Verdura)" Margin="0,0,0,20"/>

            <Button Content="Guardar Categoría" Click="btnGuardar_Click" Background="#28a745" Foreground="White" Height="35" FontWeight="Bold"/>
            <Button Content="Cancelar" Click="btnCancelar_Click" Background="#dc3545" Foreground="White" Height="35" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Page>