<Window x:Class="Invetario.Views.AdminUsuariosPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Invetario.Views"
        mc:Ignorable="d"
        Title="AdminUsuariosPage" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Administración de Usuarios" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <GroupBox Header="Datos del Usuario" Margin="0,10,0,0" Height="350">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="347*"/>
                        <ColumnDefinition Width="381*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="10,10,10,48" Grid.ColumnSpan="2">
                        <GroupBox Header="Filtros de Búsqueda" Margin="0,0,0,10">
                            <WrapPanel Margin="5">
                                <StackPanel Margin="5">
                                    <Label Content="ID / Usuario / Nombre:"/>
                                    <TextBox x:Name="txtFiltroGeneral" Width="150" TextChanged="Filtro_Changed"/>
                                </StackPanel>

                                <StackPanel Margin="5">
                                    <Label Content="Sexo:"/>
                                    <ComboBox x:Name="cmbFiltroSexo" Width="100" SelectionChanged="Filtro_Changed">
                                        <ComboBoxItem Content="Todos"/>
                                        <ComboBoxItem Content="Hombre"/>
                                        <ComboBoxItem Content="Mujer"/>
                                    </ComboBox>
                                </StackPanel>

                     <Button x:Name="btnActualizarTabla" Content="🔄 Actualizar Lista" 
                    Click="btnActualizarTabla_Click" Margin="20,20,0,0" 
                    Padding="10,0" Background="#007bff" Foreground="White"/>
                            </WrapPanel>
                        </GroupBox>

                    </StackPanel>
                    <DataGrid x:Name="dgUsuarios" AutoGenerateColumns="False" CanUserAddRows="False" Grid.ColumnSpan="2" Margin="10,116,-10,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Nombre Real" Binding="{Binding NombreReal}" Width="*"/>
                            <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="100"/>
                            <DataGridTemplateColumn Header="Sexo" Width="100">
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Sexo, UpdateSourceTrigger=PropertyChanged}" 
                                                  SelectedValuePath="Content">
                                            <ComboBoxItem Content="Hombre"/>
                                            <ComboBoxItem Content="Mujer"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Password" Binding="{Binding Password}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>
