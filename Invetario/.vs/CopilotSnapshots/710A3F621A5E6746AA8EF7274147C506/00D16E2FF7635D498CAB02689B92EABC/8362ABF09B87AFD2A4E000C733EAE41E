<Page x:Class="Invetario.Views.ListaProductosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Lista de Productos">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="📦 Lista de Productos" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="🔍 Buscar Producto:" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBox x:Name="txtFiltro" Width="300" Height="30" FontSize="16" 
             VerticalContentAlignment="Center" TextChanged="txtFiltro_TextChanged"/>
                <Label Content="Categoría:"/>
                <ComboBox x:Name="cmbCategorias" DisplayMemberPath="Nombre" SelectedValuePath="Id"/>
            </StackPanel>

            <DataGrid x:Name="dgProductos" AutoGenerateColumns="False"
                      Height="450" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Acción">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🛒 Vender" Click="btnVenderDesdeLista_Click" 
                    Background="#27ae60" Foreground="White" Padding="10,2" FontWeight="Bold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarras}" Width="150"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat=C2}" Width="100"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>
