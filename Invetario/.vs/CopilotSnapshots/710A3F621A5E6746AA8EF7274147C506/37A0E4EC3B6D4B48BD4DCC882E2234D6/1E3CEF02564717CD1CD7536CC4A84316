<Window x:Class="Invetario.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Gestión - Kiosco Pierre" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F5F6FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50" Padding="10" HorizontalAlignment="Left" Width="220">
            <StackPanel>
                <Ellipse Width="80" Height="80" Fill="#34495E" Margin="0,20,0,10"/>
                <TextBlock x:Name="lblUsuario" Text="Bienvenido!" Foreground="White" 
                           HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,30"/>
                <Button x:Name="btnVentas" Content="🛒 Nueva Venta" Height="50" Margin="0,5"
                        Background="#34495E" Foreground="White" BorderThickness="0" Click="btnVentas_Click"/>

                <Button x:Name="btnVerProductos" Content="📦 Ver Productos" Height="50" Margin="0,5"
                        Background="#34495E" Foreground="White" BorderThickness="0" Click="btnVerProductos_Click"/>

                <StackPanel x:Name="panelAdmin" Visibility="Collapsed">
                    <Button x:Name="btnAdminUsuarios" 
                        Content="👥 Gestionar Usuarios" 
                        Click="btnAdminUsuarios_Click" 
                        Background="#34495E" Foreground="White" 
                         Height="50" Margin="0,5"/>   
                    <Button x:Name="btnNuevoProducto" Content="➕ Ingresar Producto" Height="50" Margin="0,5"
                            Background="#E67E22" Foreground="White" BorderThickness="0" Click="btnNuevoProducto_Click"/>

                    <Button x:Name="btnModificar" Content="📝 Modificar Stock" Height="50" Margin="0,5"
                            Background="#34495E" Foreground="White" BorderThickness="0" Click="btnModificar_Click"/>

                    <Button x:Name="btnIrANuevaCategoria" Content="➕ Nueva Categoría" 
        Click="btnIrANuevaCategoria_Click" 
       Height="50" Margin="0,5"
        Background="#34495E" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                

                <Button x:Name="btnSalir" Content="🚪 Cerrar Sesión" Height="50" Margin="0,100,0,0"
                        Background="#C0392B" Foreground="White" BorderThickness="0" Click="btnSalir_Click"/>
            </StackPanel>
        </Border>

        <Frame Grid.Column="1" x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="20"/>
    </Grid>
</Window>
