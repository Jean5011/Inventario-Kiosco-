<Page x:Class="Invetario.Views.ReportesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reportes de Ventas" Background="White">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Periodo:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <ComboBox x:Name="cmbPeriodo" Width="150" SelectionChanged="cmbPeriodo_SelectionChanged">
                    <ComboBoxItem Content="Hoy" IsSelected="True"/>
                    <ComboBoxItem Content="Esta Semana"/>
                    <ComboBoxItem Content="Este Mes"/>
                    <ComboBoxItem Content="Este Año"/>
                    <ComboBoxItem Content="Día específico"/>
                    <ComboBoxItem Content="Mes específico"/>
                    <ComboBoxItem Content="Año específico"/>
                    <ComboBoxItem Content="Todas"/>
                </ComboBox>

                <TextBlock x:Name="lblTotalPeriodo" Text="Total: $0.00" FontSize="20" 
                           Foreground="#28a745" FontWeight="Bold" Margin="50,0,0,0"/>
            </StackPanel>

            <StackPanel x:Name="panelFiltroFecha" Orientation="Horizontal" Visibility="Collapsed">
                <TextBlock Text="Fecha:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <DatePicker x:Name="dpFecha" Width="150" SelectedDateChanged="dpFecha_SelectedDateChanged"/>
            </StackPanel>

            <StackPanel x:Name="panelFiltroMes" Orientation="Horizontal" Visibility="Collapsed">
                <TextBlock Text="Mes:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <ComboBox x:Name="cmbMes" Width="130" SelectionChanged="cmbMesAnio_SelectionChanged">
                    <ComboBoxItem Content="Enero" Tag="1"/>
                    <ComboBoxItem Content="Febrero" Tag="2"/>
                    <ComboBoxItem Content="Marzo" Tag="3"/>
                    <ComboBoxItem Content="Abril" Tag="4"/>
                    <ComboBoxItem Content="Mayo" Tag="5"/>
                    <ComboBoxItem Content="Junio" Tag="6"/>
                    <ComboBoxItem Content="Julio" Tag="7"/>
                    <ComboBoxItem Content="Agosto" Tag="8"/>
                    <ComboBoxItem Content="Septiembre" Tag="9"/>
                    <ComboBoxItem Content="Octubre" Tag="10"/>
                    <ComboBoxItem Content="Noviembre" Tag="11"/>
                    <ComboBoxItem Content="Diciembre" Tag="12"/>
                </ComboBox>
                <TextBlock Text="Año:" VerticalAlignment="Center" Margin="15,0,10,0" FontWeight="Bold"/>
                <TextBox x:Name="txtAnioMes" Width="80" Text="" VerticalContentAlignment="Center" TextChanged="txtAnio_TextChanged"/>
            </StackPanel>

            <StackPanel x:Name="panelFiltroAnio" Orientation="Horizontal" Visibility="Collapsed">
                <TextBlock Text="Año:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <TextBox x:Name="txtAnio" Width="80" Text="" VerticalContentAlignment="Center" TextChanged="txtAnio_TextChanged"/>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="dgVentas" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Venta" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="*"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="*"/>
                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="120"/>

                <DataGridTemplateColumn Header="Acciones" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="👁 Ver Ticket" Click="btnVerTicket_Click" 
                                    Background="#17a2b8" Foreground="White" Padding="5,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>