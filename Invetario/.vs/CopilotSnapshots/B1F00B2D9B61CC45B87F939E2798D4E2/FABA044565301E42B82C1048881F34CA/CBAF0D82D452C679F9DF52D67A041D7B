namespace Invetario.Views
{
    /// <summary>
    /// Lógica de interacción para ReportesPage.xaml
    /// </summary>
    public partial class ReportesPage 
    {
        public ReportesPage()
        {
            InitializeComponent();
        }
        private void btnVerDetalleTicket_Click(object sender, RoutedEventArgs e)
        {
            // Capturamos la fila seleccionada del DataGrid
            var ventaSeleccionada = (VentaReporte)((Button)sender).DataContext;

            if (ventaSeleccionada != null)
            {
                // Reutilizamos tu ventana de Ticket pasándole el Id de la venta
                TicketWindow ventanaTicket = new TicketWindow(ventaSeleccionada.Id);
                ventanaTicket.ShowDialog();
            }
        }
        private void btnVerTicket_Click(object sender, RoutedEventArgs e)
        {
            // Obtenemos la fila seleccionada (usamos dynamic porque el query devuelve columnas de dos tablas)
            var venta = (sender as Button).DataContext as dynamic;

            if (venta != null)
            {
                // Abrimos el ticket que ya tenés programado
                var ticketWin = new TicketWindow(venta.Id);
                ticketWin.ShowDialog();
            }
        }
    }
}
