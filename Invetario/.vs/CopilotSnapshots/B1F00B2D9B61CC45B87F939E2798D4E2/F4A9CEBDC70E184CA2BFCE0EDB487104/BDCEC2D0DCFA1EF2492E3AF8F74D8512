<Page x:Class="Invetario.Views.AdminUsuariosPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Invetario.Views"
        xmlns:conv="clr-namespace:Invetario.Converters"
        mc:Ignorable="d"
        Title="AdminUsuariosPage" Background="White">
    <Grid>
        <Grid.Resources>
            <conv:SexoToImageConverter x:Key="SexoToImageConverter"/>
        </Grid.Resources>
        <DockPanel Margin="20">
            <TextBlock Text="Administración de Usuarios" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <GroupBox Header="Datos del Usuario" Margin="0,10,0,0">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="347*"/>
                        <ColumnDefinition Width="381*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="10,10,10,48" Grid.ColumnSpan="2">
                        <GroupBox Header="Filtros de Búsqueda" Margin="0,0,0,10">
                            <WrapPanel Margin="5">
                                <StackPanel Margin="5">
                                    <Label Content="ID / Usuario / Nombre:"/>
                                    <TextBox x:Name="txtFiltroGeneral" Width="150" TextChanged="Filtro_Changed"/>
                                </StackPanel>

                                <StackPanel Margin="5">
                                    <Label Content="Sexo:"/>
                                    <ComboBox x:Name="cmbFiltroSexo" Width="100" SelectionChanged="Filtro_Changed">
                                        <ComboBoxItem Content="Todos"/>
                                        <ComboBoxItem Content="Hombre"/>
                                        <ComboBoxItem Content="Mujer"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="5">
                                    <Label Content="Rol:"/>
                                    <ComboBox x:Name="cmbFiltroRol" Width="100" SelectionChanged="Filtro_Changed">
                                        <ComboBoxItem Content="Todos"/>
                                        <ComboBoxItem Content="Admin"/>
                                        <ComboBoxItem Content="Empleado"/>
                                    </ComboBox>
                                </StackPanel>

                     <Button x:Name="btnActualizarTabla" Content="🔄 Actualizar Lista" 
                    Click="btnActualizarTabla_Click" Margin="20,20,0,0" 
                    Padding="10,0" Background="#007bff" Foreground="White"/>

                     <Button x:Name="btnAgregarUsuario" Content="➕ Agregar Usuario" 
                    Click="btnAgregarUsuario_Click" Margin="10,20,0,0" 
                    Padding="10,0" Background="#28a745" Foreground="White" FontWeight="Bold"/>
                            </WrapPanel>
                        </GroupBox>

                    </StackPanel>
                    <DataGrid x:Name="dgUsuarios" AutoGenerateColumns="False" CanUserAddRows="False" Grid.ColumnSpan="2" Margin="10,116,-10,10">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Foto" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Sexo, Converter={StaticResource SexoToImageConverter}}" Width="35" Height="35"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Nombre Real" Binding="{Binding NombreReal}" Width="*"/>
                            <DataGridTemplateColumn Header="Rol" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Rol}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Rol, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Content">
                                            <ComboBoxItem Content="Admin"/>
                                            <ComboBoxItem Content="Empleado"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Sexo" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Sexo}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Sexo, UpdateSourceTrigger=PropertyChanged}" 
                                                  SelectedValuePath="Content">
                                            <ComboBoxItem Content="Hombre"/>
                                            <ComboBoxItem Content="Mujer"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Password" Width="180" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="txtPass" Text="••••••" VerticalAlignment="Center"/>
                                            <TextBox x:Name="txtPassEdit" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                                                     Visibility="Collapsed" VerticalAlignment="Center" Width="100"/>
                                            <ToggleButton x:Name="btnToggle" Content="👁" Width="25" Margin="5,0,0,0" 
                                                          Checked="TogglePassword_Checked" Unchecked="TogglePassword_Unchecked"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Acción" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Modificar" Click="btnModificarUsuario_Click" 
                                                    Background="#28a745" Foreground="White" Padding="5,2"/>
                                            <Button Content="Eliminar" Click="btnEliminarUsuario_Click" 
                                                    Background="#dc3545" Foreground="White" Padding="5,2" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0" Grid.ColumnSpan="2" VerticalAlignment="Bottom">
                        <Button Content="⬅ Anterior" Click="btnPaginaAnterior_Click" Width="100" Margin="5"/>
                        <TextBlock x:Name="txtPagina" Text="Página 1" VerticalAlignment="Center" FontWeight="Bold" Margin="10,0"/>
                        <Button Content="Siguiente ➡" Click="btnPaginaSiguiente_Click" Width="100" Margin="5"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </DockPanel>
    </Grid>
</Page>
